{
  "name": "identity-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev:web": "pnpm --filter @identity-starter/web dev",
    "dev:admin": "pnpm --filter @identity-starter/admin dev",
    "dev:all": "turbo run dev",
    "db:generate": "pnpm --filter @identity-starter/db generate",
    "db:migrate": "pnpm --filter @identity-starter/db migrate",
    "test:e2e": "./scripts/e2e.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "@node-rs/argon2"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
