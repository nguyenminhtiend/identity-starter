{
  "name": "identity-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "pnpm --filter @identity-starter/db generate",
    "db:migrate": "pnpm --filter @identity-starter/db migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "@node-rs/argon2"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
