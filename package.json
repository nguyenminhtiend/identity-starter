{
	"name": "identity-starter",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"db:generate": "pnpm --filter @identity-starter/db generate",
		"db:migrate": "pnpm --filter @identity-starter/db migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"lefthook": "^1.10.10",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3"
	},
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=22"
	}
}
