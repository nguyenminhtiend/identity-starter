# Server API URL
API_URL=http://localhost:3001

# Display name
NEXT_PUBLIC_APP_NAME=Identity Admin

# OAuth client credentials (from seed or admin API)
ADMIN_OAUTH_CLIENT_ID=admin-dashboard
ADMIN_OAUTH_CLIENT_SECRET=<generate-with-openssl-rand-base64-32>

# IdP URLs
IDP_ISSUER_URL=http://localhost:3100
IDP_API_URL=http://localhost:3001

# OAuth callback URL
ADMIN_OAUTH_REDIRECT_URI=http://localhost:3002/auth/callback

# Token encryption key (min 32 chars — generate with: openssl rand -hex 16)
ADMIN_SESSION_SECRET=0123456789abcdef0123456789abcdef
