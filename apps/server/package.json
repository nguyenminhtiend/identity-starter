{
  "name": "@identity-starter/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch --env-file .env src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@identity-starter/core": "workspace:*",
    "@identity-starter/db": "workspace:*",
    "@identity-starter/redis": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@simplewebauthn/server": "^13.3.0",
    "drizzle-orm": "^0.45.1",
    "emittery": "^2.0.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^6.2.2",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
